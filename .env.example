# --------------------------------------------------------------------------
# Build-time env vars. Copy to `.env.local` to override locally, or set them
# on your host (Vercel: Project → Settings → Environment Variables).
# Only variables prefixed with `VITE_` reach the client bundle.
# --------------------------------------------------------------------------

# Google Analytics 4 — paste your "G-XXXXXXXXXX" measurement ID. Leave blank
# (or omit the variable entirely) to disable GA. See src/lib/analytics.ts.
VITE_GA_ID=

# Vercel Web Analytics is auto-enabled by `@vercel/analytics` on every Vercel
# deploy that has Analytics turned on (Project → Analytics → Enable). No env
# var needed; the package no-ops elsewhere.
