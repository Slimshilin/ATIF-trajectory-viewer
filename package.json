{
  "name": "atif-trajectory-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "bridge": "node bridge/aft-bridge.mjs",
    "bridge:docker": "ANALYZER_RUNTIME=docker node bridge/aft-bridge.mjs",
    "analyzer:image": "docker build -t aft-analyzer -f bridge/analyzer.Dockerfile bridge",
    "aft:batch": "node bridge/aft-batch.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "driver.js": "1.3",
    "fflate": "^0.8.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
